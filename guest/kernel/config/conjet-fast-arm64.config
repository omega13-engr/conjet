# Conjet Pulse fast ARM64 direct-kernel config fragment.
# Seed an upstream arm64 allnoconfig build with KCONFIG_ALLCONFIG.
#
# This profile is intentionally not the full Docker appliance kernel. It keeps
# the direct-OCI Pulse substrate built in and leaves serial console support out
# of the fast lane; use conjet-arm64.config for the debug/Docker profile.

CONFIG_LOCALVERSION="-conjet-fast"

# Keep the fast profile production-hardened without enabling sanitizers or
# other instrumentation that would affect steady-state container throughput.
CONFIG_RANDOMIZE_BASE=y
CONFIG_STACKPROTECTOR=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_FORTIFY_SOURCE=y
CONFIG_HARDENED_USERCOPY=y
CONFIG_SLAB_FREELIST_HARDENED=y
CONFIG_SLAB_FREELIST_RANDOM=y
CONFIG_SHUFFLE_PAGE_ALLOCATOR=y
CONFIG_BPF_UNPRIV_DEFAULT_OFF=y
CONFIG_STRICT_KERNEL_RWX=y
CONFIG_UNMAP_KERNEL_AT_EL0=y
CONFIG_INIT_STACK_ALL_ZERO=y
# CONFIG_DEBUG_FS is not set
# CONFIG_MAGIC_SYSRQ is not set
# CONFIG_USERFAULTFD is not set

# Keep balloon allocations aligned with the native 16 KiB host granule. The
# virtio interface remains 4 KiB-PFN based; Linux submits all four PFNs for a
# 16 KiB base page together, allowing safe whole-granule reclaim.
# CONFIG_ARM64_4K_PAGES is not set
CONFIG_ARM64_16K_PAGES=y

# Boot substrate.
CONFIG_OF=y
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=y
CONFIG_DUMMY_CONSOLE=y
CONFIG_ARM_GIC=y
CONFIG_ARM_GIC_V3=y
CONFIG_ARM_ARCH_TIMER=y

# Virtio-mmio devices used by the Pulse microVM.
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_MMIO_CMDLINE_DEVICES=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_BALLOON=y
CONFIG_PAGE_REPORTING=y
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS_COMMON=y

# Filesystems and process primitives for immutable rootfs + sparse scratch.
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_LOOP_MIN_COUNT=8
CONFIG_PARTITION_ADVANCED=y
CONFIG_EFI_PARTITION=y
CONFIG_MSDOS_PARTITION=y
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_OVERLAY_FS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_INOTIFY_USER=y
CONFIG_EPOLL=y

# Direct OCI process isolation.
CONFIG_NAMESPACES=y
CONFIG_SYSVIPC=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y
CONFIG_CGROUPS=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CPUSETS=y
CONFIG_MEMCG=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_KEYS=y
CONFIG_POSIX_MQUEUE=y
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y

# Minimal reclaim support for Pulse direct-OCI guests.
CONFIG_COMPACTION=y
CONFIG_BALLOON_COMPACTION=y
CONFIG_PSI=y
CONFIG_SWAP=y
CONFIG_ZSMALLOC=y
CONFIG_ZRAM=y

# Minimal networking for vmnet-backed Pulse workloads.
CONFIG_NET=y
CONFIG_INET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y

# Keep boot logs available through dmesg when explicitly collected, without
# exposing DebugFS or Magic SysRq controls in the fast profile.
CONFIG_PRINTK=y
